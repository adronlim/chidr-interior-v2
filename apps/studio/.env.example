# Fill these after creating the Sanity project (see docs/CMS.md → Studio setup).
#
# 1. Run `yarn workspace studio exec sanity init` once — it creates the project
#    on sanity.io and writes the IDs back here.
# 2. Generate an Editor-scoped token at sanity.io → API → Tokens and paste it
#    into SANITY_AUTH_TOKEN below (only needed for the seed script).

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Used ONLY by scripts/seed.ts — never committed.
SANITY_AUTH_TOKEN=
